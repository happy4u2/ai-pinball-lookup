{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ServiceHistoryAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:GetItem",
        "dynamodb:Query",
        "dynamodb:UpdateItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:eu-central-1:465443875879:table/pinball_service_history",
        "arn:aws:dynamodb:eu-central-1:465443875879:table/pinball_service_history/index/*"
      ]
    }
  ]
}
